# Instagram Graph API
# Jak získat token: viz README.md sekce "Instagram setup"
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here
INSTAGRAM_USER_ID=your_instagram_user_id_here

# Resend - odesílání emailů z kontaktního formuláře
# Registrace zdarma na https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# Email kam přijdou zprávy z kontaktního formuláře
CONTACT_EMAIL=info@podlahyperk.cz

# Veřejná URL webu (pro sitemap a OG tagy)
NEXT_PUBLIC_SITE_URL=https://www.podlahyperk.cz
